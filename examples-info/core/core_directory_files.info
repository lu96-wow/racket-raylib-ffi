;; core_directory_files — 设计要点
;;
;; 对应 C: examples/core/core_directory_files.c
;; 功能:  文件目录浏览器 (过滤 .png;.c; 目录)
;;
;; ============================================================
;; 核心问题: C 原版用 raygui, Racket 版无法绑定
;; ============================================================
;;
;; raygui 是独立的纯头文件库 (raygui.h), 不在 libraylib.so 中。
;; 在所有 raylib C 示例中, raygui 都是通过:
;;   #define RAYGUI_IMPLEMENTATION
;;   #include "raygui.h"
;; 在编译时展开到 .c 文件中的, 没有独立的 .so 可 FFI 链接。
;;
;; Racket 版用原生 raylib 绘制替代 raygui 控件:
;;
;;   C (raygui)              →  Racket (原生 raylib)
;;   ─────────────────────────────────────────────
;;   GuiButton()             →  DrawRectangleRec + DrawText + 鼠标碰撞检测
;;   GuiLabel()              →  DrawText
;;   GuiListViewEx()         →  for 循环逐项 DrawRectangle + DrawText
;;   GuiSetStyle()           →  不适用 (直接控制颜色/大小)
;;   GuiGetFont()            →  不适用 (直接用固定字号)
;;
;; 这跟 core_storage_values 用 Racket file I/O 替代
;; LoadFileData/SaveFileData 的思路一致: 不绑无关库。
;;
;; ============================================================
;; 新增 FFI 绑定
;; ============================================================
;;
;; get-working-directory     — GetWorkingDirectory(), 返回 _string
;; get-prev-directory-path   — GetPrevDirectoryPath(_string), 返回 _string
;; directory-exists?         — DirectoryExists(_string), 返回 _stdbool
;; load-directory-files-ex   — LoadDirectoryFilesEx() 的包装:
;;   接受 basePath, filter, scanSubdirs
;;   自动调用 UnloadDirectoryFiles 释放 C 内存
;;   返回 Racket 字符串列表 (不持 C 指针)
;;
;; 复用 _filepathlist-bytes 类型 (来自 core_drop_files 的 FilePathList 传值类型)
;;
;; ============================================================
;; 已有绑定复用
;; ============================================================
;;
;; init-window close-window window-should-close?
;; set-target-fps
;; begin-drawing end-drawing clear-background
;; draw-text draw-rectangle draw-rectangle-rec
;; get-mouse-position is-mouse-button-pressed
;; check-collision-point-rec
