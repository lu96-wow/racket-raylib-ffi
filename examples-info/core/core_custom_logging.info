;; core_custom_logging — 设计要点
;;
;; 对应 C: examples/core/core_custom_logging.c
;; 功能:  拦截 raylib 所有日志输出, 替换为自定义格式
;;
;; ============================================================
;; 新增 FFI 绑定
;; ============================================================
;;
;;  set-trace-log-callback  — SetTraceLogCallback(TraceLogCallback)
;;  vsnprintf               — C 标准库, 展开 va_list 到缓冲区
;;
;; ============================================================
;; 核心问题: Racket 无法操作 C 的 va_list
;; ============================================================
;;
;; 回调签名:
;;   void (*callback)(int logLevel, const char *text, va_list args)
;;
;; args 是 C 的可变参数列表指针, 内存布局依赖平台 ABI
;; (x86-64 Linux 下是 struct { gp_offset; fp_offset;
;;   overflow_arg_area; reg_save_area })
;;
;; Racket 无法:
;;   1. 知道 args 指向什么类型的数据
;;   2. 知道有多少个参数
;;   3. 按 C ABI 从寄存器/栈上正确读取
;;
;; 即使用 ptr-ref 强行读内存, 也无法解析, 因为格式信息
;; 只在 text(格式字符串) 中, Racket 不认识 %s/%d 语法。
;;
;; ============================================================
;; 设计方案: C 只展开, Racket 全控
;; ============================================================
;;
;;   C 层 (vsnprintf):   va_list + text → 完整字符串 (写到缓冲区)
;;   Racket 层:          拿到字符串, 自由处理
;;
;; 数据流:
;;   raylib C: TraceLog(LOG_INFO, "Screen: %ix%i", w, h)
;;     ↓
;;   回调收到: text="Screen: %ix%i", args=变参指针
;;     ↓
;;   vsnprintf(buf, 4096, text, args)
;;     ↓ buf = "Screen: 800x450\0"
;;   bytes->string/utf-8(subbytes buf 0 len)
;;     ↓ msg = "Screen: 800x450"
;;   printf "[Custom Log] [INFO] ~a~n" msg
;;
;; 为什么 vsnprintf 而不是 vprintf:
;;   vprintf   → 直接打印到 stdout (C 做了输出)
;;   vsnprintf → 写到缓冲区, 不输出 (C 只展开)
;;
;; 为什么不用 vprintf + 重定向 stdout:
;;   技术上可以, 但更复杂, 且需要处理 Racket 和 C
;;   共享 stdout 的缓冲问题。
;;
;; ============================================================
;; 回调创建: function-ptr
;; ============================================================
;;
;; 使用 (function-ptr proc ffi-type) 将 Racket λ 函数
;; 转换为 C 可调用的函数指针 (#<callback>)。
;;
;; 注意必须 keep 住 callback 对象不被 GC 回收,
;; 否则 C 侧调用时会崩溃。当前用 define 绑定到
;; 模块顶层变量, 保证存活。
;;
;; ============================================================
;; 日志级别映射
;; ============================================================
;;
;; raylib 定义:
;;   LOG_INFO    = 1
;;   LOG_WARNING = 2
;;   LOG_ERROR   = 4
;;   LOG_DEBUG   = 8
;;
;; 初始化阶段 raylib 使用日志级别 3 (内部 TRACE),
;; 不在公开枚举中, 故 case else 兜底显示数字。
;;
;; ============================================================
;; 已有绑定复用
;; ============================================================
;;
;; 全部已有, 无需新增:
;;   init-window close-window window-should-close?
;;   set-target-fps
;;   begin-drawing end-drawing clear-background
;;   draw-text
