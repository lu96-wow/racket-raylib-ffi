;; shapes_recursive_tree — 设计要点
;;
;; 对应 C: examples/shapes/shapes_recursive_tree.c
;; 功能:  递归生成二叉树, 键盘控制参数

;; ============================================================
;; 主要区别: 键盘替代 raygui 滑块
;; ============================================================
;;
;; C 原版用 raygui 提供 5 个滑块 (Angle/Length/Decay/Depth/Thick)
;; 和 1 个复选框 (Bezier)。
;;
;; raygui 是纯头文件库 (raygui.h), 不在 libraylib.so 中,
;; 无法通过 FFI 链接。Racket 版用键盘控制:
;;
;;   Q/W → Angle   ±2°    范围 0-180
;;   A/S → Length  ±5     范围 12-240
;;   Z/X → Decay   ±0.02  范围 0.1-0.78
;;   E/R → Depth   ±1     范围 1-10
;;   D/F → Thick   ±1     范围 1-8
;;   T   → Bezier 切换

;; ============================================================
;; 实现差异
;; ============================================================
;;
;; 1. 分支生成使用 named-let (iter) 传递 count 参数,
;;    避免原始 Racket 翻译用 set! 修改外层 let* 变量的副作用,
;;    保证尾调用优化, 不消耗栈空间。
;;
;; 2. 所有可变状态用 box (angle/thick/depth/decay/len/bezier?)
;;    替代 define + set!。
;;
;; 3. 不绑定 raygui / raymath 等额外库。

;; ============================================================
